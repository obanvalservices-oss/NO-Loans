# Copy to `.env.local` for local development (never commit real secrets).

# --- Required in production (min 32 random characters) ---
# openssl rand -base64 48
AUTH_SECRET=

# --- PostgreSQL (Supabase: Project Settings → Database → Connection string → URI) ---
# Use the direct connection (port 5432) for migrations and local dev.
DATABASE_URL=

# --- First admin when the database has no users (production) ---
# Dev default remains admin@local.com / 123456 when these are unset.
# ADMIN_SEED_EMAIL=admin@yourcompany.com
# ADMIN_SEED_PASSWORD=

# --- Logging: silent | error | warn | info | debug ---
# LOG_LEVEL=info
