# Copy to `.env.local` for local development (never commit real secrets).

# --- Required in production (min 32 random characters) ---
# openssl rand -base64 48
AUTH_SECRET=

# --- PostgreSQL / Supabase (direct connection, port 5432) ---
# Replace [YOUR-PASSWORD] with your database password (Settings → Database).
# Used by Prisma Migrate (`npm run db:migrate:deploy`) and the app (`src/lib/prisma.ts`).
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.dxbiecijlmmqyxplliuu.supabase.co:5432/postgres"
#
# If the DB was created earlier with `prisma db push` and you add migrations later, baseline once:
# npx prisma migrate resolve --applied 20260330120000_init

# --- First admin when the database has no users (production) ---
# Dev default remains admin@local.com / 123456 when these are unset.
# ADMIN_SEED_EMAIL=admin@yourcompany.com
# ADMIN_SEED_PASSWORD=

# --- Logging: silent | error | warn | info | debug ---
# LOG_LEVEL=info
